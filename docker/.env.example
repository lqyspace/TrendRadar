# ============================================
# Web server
# ============================================
# Web report port (default 8080)
WEBSERVER_PORT=8080

# ============================================
# Notification channels (multi-account uses ';')
# ============================================
FEISHU_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DINGTALK_WEBHOOK_URL=
WEWORK_WEBHOOK_URL=
WEWORK_MSG_TYPE=markdown

# Email (EMAIL_TO supports comma-separated recipients)
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=

# ntfy
NTFY_SERVER_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=

# Bark
BARK_URL=

# Slack
SLACK_WEBHOOK_URL=

# Generic webhook
GENERIC_WEBHOOK_URL=
# Example: {"content": "{content}"}
GENERIC_WEBHOOK_TEMPLATE=

# ============================================
# AI settings (shared by ai_analysis / ai_translation / ai_filter)
# ============================================
AI_ANALYSIS_ENABLED=true
AI_API_KEY=
# LiteLLM model format: provider/model_name
AI_MODEL=deepseek/deepseek-chat
AI_API_BASE=

# ============================================
# Remote storage (S3-compatible, optional)
# ============================================
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# ============================================
# MCP server (optional)
# ============================================
MCP_HOST=127.0.0.1
MCP_PORT=3333

# ============================================
# Runtime
# ============================================
# Cron expression, default every 30 minutes
CRON_SCHEDULE=*/30 * * * *
# cron | once
RUN_MODE=cron
# Run once immediately on startup
IMMEDIATE_RUN=true
